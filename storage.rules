rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Tarkista onko käyttäjä admin roolissa (tarkistaa Firestoresta)
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    
    // Tuotekuvat - kaikki voivat lukea, vain admin voi kirjoittaa
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Käyttäjäkuvat - käyttäjät voivat lukea ja kirjoittaa omia kuviaan
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Oletussääntö - ei pääsyä muihin tiedostoihin
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
