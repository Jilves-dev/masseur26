rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /userInteractions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.user.uid ||
         resource.data.userId == request.auth.uid);
      allow write: if request.auth != null;
    }

    // Booking availability — public read so unauthenticated customers can see dates
    match /availability/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Bookable services list — public read, admin write
    match /services/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Customer bookings — anyone can create, only auth can read/update/delete
    match /bookings/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Firebase Trigger Email extension — anyone can enqueue, only auth can read
    match /mail/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Default: authenticated users only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}